APP_NAME=delayed-notifier-test
APP_VERSION=1.0.0

ENV=local

HTTP_HOST=0.0.0.0
HTTP_IDLE_TIMEOUT=60s
HTTP_MAX_HEADER_BYTES=1048576
HTTP_PORT=8080
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=5s
HTTP_SHUTDOWN_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=5s

DB_HOST=db
DB_NAME=notify_db
DB_PASSWORD=postgres
DB_PORT=5432
DB_SSL_MODE=disable
DB_USER=postgres

DB_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=${DB_SSL_MODE}

CACHE_ADDR=notifier-redis:6379
CACHE_MIN_IDLE_CONS=10
CACHE_PASSWORD=
CACHE_POOL_SIZE=20
CACHE_POOL_TIMEOUT=4s

RABBIT_ATTEMPTS=3
RABBIT_BACKOFF=2.0
RABBIT_CONNECTION_NAME=delayed-notifier-publisher
RABBIT_CONNECT_TIMEOUT=30s
RABBIT_CONTENT_TYPE=application/json
RABBIT_DELAY=1s
RABBIT_EXCHANGE=notifications
RABBIT_HEARTBEAT=10s
RABBIT_URL=amqp://guest:guest@notifier-rabbitmq:5672/

SERVICE_MAX_RETRIES=3
SERVICE_QUERY_LIMIT=10
SERVICE_RETRY_DELAY=5m

SMTP_FROM=noreply@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PASSWORD=
SMTP_PORT=587
SMTP_USERNAME=

TG_TOKEN=5367696164:AAHX8QGlpmlTMcvzgcx5QmYnv9KDs1X231I

LOGGER_FILENAME=./logs/delayed-notifier.log
LOGGER_LEVEL=info
LOGGER_MAX_AGE=28
LOGGER_MAX_BACKUPS=3
LOGGER_MAX_SIZE=100
