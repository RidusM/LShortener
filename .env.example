APP_NAME=lshortener-test
APP_VERSION=1.0.0

ENV=local

HTTP_HOST=0.0.0.0
HTTP_IDLE_TIMEOUT=60s
HTTP_MAX_HEADER_BYTES=1048576
HTTP_PORT=8080
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=5s
HTTP_SHUTDOWN_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=5s

DB_HOST=db
DB_NAME=lshortener_db
DB_PASSWORD=postgres
DB_PORT=5432
DB_SSL_MODE=disable
DB_USER=postgres

DB_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=${DB_SSL_MODE}

CACHE_ADDR=lshortener-redis:6379
CACHE_MIN_IDLE_CONS=10
CACHE_PASSWORD=
CACHE_POOL_SIZE=20
CACHE_POOL_TIMEOUT=4s

SERVICE_BASE_URL=http://localhost:8080
SERVICE_DEFAULT_TTL=0
SERVICE_MAX_RETRIES=5
SERVICE_QUERY_LIMIT=10
SERVICE_RETRY_DELAY=10ms
SERVICE_SHORT_CODE_LENGTH=6

LOGGER_FILENAME=./logs/lshortener.log
LOGGER_LEVEL=info
LOGGER_MAX_AGE=28
LOGGER_MAX_BACKUPS=3
LOGGER_MAX_SIZE=100
